# Database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/personal_epistemology?schema=public"

# Auth (required for login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
SESSION_SECRET="generate-a-long-random-string-at-least-16-chars"

# DeepSeek AI (optional — AI page works but returns a config message without it)
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# App URLs
# Local dev: API on 3000, Vite on 5173
APP_URL="http://localhost:3000"
CLIENT_URL="http://localhost:5173"

# Production VPS: set both to your public HTTPS URL (same origin)
# APP_URL="https://your-domain.com"
# CLIENT_URL="https://your-domain.com"
# COOKIE_SECURE="true"   # required when behind HTTPS reverse proxy (nginx)

NODE_ENV="development"
PORT="3000"
