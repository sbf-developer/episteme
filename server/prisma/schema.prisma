generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  overviewLayout Json?
  aiInstructions String   @default("Give me short, direct answers.")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions      Session[]
  documents     Document[]
  goals         Goal[]
  actions       Action[]
  connections   Connection[]
  aiThreads     AiThread[]
  calendarEvents CalendarEvent[]
  fileUploads   FileUpload[]
  graphLayouts  GraphLayout[]
  kpis          Kpi[]
  doItems       DoItem[]

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Document {
  id          String       @id @default(cuid())
  userId      String
  title       String
  content     String       @default("")
  type        DocumentType @default(NOTE)
  parentId    String?
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Document?  @relation("DocumentTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Document[] @relation("DocumentTree")

  @@index([userId])
  @@index([type])
  @@index([parentId])
}

enum DocumentType {
  NOTE
  OUTLINE
  PLAN
}

model Goal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String     @default("")
  status      GoalStatus @default(ACTIVE)
  priority    Int        @default(0)
  targetDate  DateTime?
  parentId    String?
  position    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Goal?    @relation("GoalTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Goal[]   @relation("GoalTree")
  actions  Action[]

  @@index([userId])
  @@index([status])
  @@index([parentId])
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ARCHIVED
}

model Action {
  id          String       @id @default(cuid())
  userId      String
  goalId      String?
  title       String
  description String       @default("")
  status      ActionStatus @default(TODO)
  dueDate     DateTime?
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([goalId])
  @@index([status])
}

enum ActionStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

model Connection {
  id         String         @id @default(cuid())
  userId     String
  sourceType EntityType
  sourceId   String
  targetType EntityType
  targetId   String
  label      String?
  createdAt  DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, sourceId, targetType, targetId])
  @@index([userId])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
}

enum EntityType {
  DOCUMENT
  GOAL
  ACTION
  CALENDAR_EVENT
  FILE
}

model CalendarEvent {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String   @default("")
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean  @default(false)
  color       String?
  goalId      String?
  actionId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startAt])
  @@index([goalId])
  @@index([actionId])
}

model FileUpload {
  id           String   @id @default(cuid())
  userId       String
  filename     String
  mimeType     String
  size         Int
  storagePath  String
  extractedText String  @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GraphLayout {
  id        String   @id @default(cuid())
  userId    String
  nodeKey   String
  x         Float
  y         Float
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeKey])
  @@index([userId])
}

model AiThread {
  id        String      @id @default(cuid())
  userId    String
  title     String      @default("New conversation")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId])
}

model AiMessage {
  id        String      @id @default(cuid())
  threadId  String
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())

  thread AiThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Kpi {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String   @default("")
  currentValue Float    @default(0)
  targetValue  Float
  unit         String   @default("")
  goalId       String?
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([goalId])
}

model DoItem {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String    @default("")
  done        Boolean   @default(false)
  dueDate     DateTime?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([done])
}
